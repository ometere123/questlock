# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=

# Contract addresses (fill after deployment)
NEXT_PUBLIC_QUESTLOCK_CORE_ADDRESS=
NEXT_PUBLIC_QUEST_REWARD_TOKEN_ADDRESS=
NEXT_PUBLIC_QUEST_BADGE_ADDRESS=

# EAS
NEXT_PUBLIC_EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021
NEXT_PUBLIC_EAS_SCHEMA_UID=

# Database
# DATABASE_URL is the pooled connection (used at runtime)
# DIRECT_URL is a non-pooled connection used by Prisma Migrate. With Supabase
# you can point both at the pooler — port 6543 for DATABASE_URL (with
# ?pgbouncer=true) and port 5432 for DIRECT_URL.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub REST API (raises rate limits when reading public repos)
GITHUB_TOKEN=

# GitHub OAuth App (v1.1 — required for GitHub account linking)
# Create at https://github.com/settings/developers → New OAuth App
# Authorization callback URL must match GITHUB_OAUTH_REDIRECT_URI exactly.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Wallet keys (server-side only — never expose to client)
DEPLOYER_PRIVATE_KEY=
VERIFIER_PRIVATE_KEY=

# Network
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Admin wallet (for admin-only API routes)
ADMIN_WALLET_ADDRESS=

# Optional: shared secret used by /api/indexer trigger and by the GitHub
# OAuth state HMAC. If unset, VERIFIER_PRIVATE_KEY is used as the HMAC key.
INDEXER_SECRET=
