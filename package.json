{
  "name": "questlock",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:contracts": "npx hardhat test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "ts-node --project tsconfig.scripts.json prisma/seed.ts",
    "contracts:compile": "npx hardhat compile",
    "contracts:deploy": "npx hardhat run scripts/deploy.ts --network baseSepolia",
    "contracts:grant-roles": "npx hardhat run scripts/grant-roles.ts --network baseSepolia",
    "contracts:seed-quest": "npx hardhat run scripts/seed-quest.ts --network baseSepolia"
  },
  "dependencies": {
    "@ethereum-attestation-service/eas-sdk": "^2.7.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@prisma/client": "^5.22.0",
    "@privy-io/react-auth": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ethers": "^6.13.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.0",
    "wagmi": "^2.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.12",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.6",
    "@nomicfoundation/hardhat-viem": "^3.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "hardhat": "^3.7.0",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "postcss": "^8.4.45",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "axios": "1.17.0",
    "lodash-es": "4.18.1",
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.7",
    "undici": "6.26.0",
    "ws": "8.21.0"
  }
}
